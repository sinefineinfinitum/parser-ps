@class final SineFine\Ponymator\Analyzer\Visitor\CrossReferenceScannerVisitor
>PhpParser\NodeVisitorAbstract
!-BUILTIN_TYPES=[]
$-currentEntity:string|null=null
$-entityFqns:array=[]
$-pairs:array=[]
.-addReference
    $name:\PhpParser\Node\Name
    $referencingFqn:string
    :void
.+enterNode
    $node:\PhpParser\Node
.+getEntityFqns
    :array
.+getPairs
    :array
.-processTypeNode
    $typeNode:\PhpParser\Node
    $referencingFqn:string
    :void
