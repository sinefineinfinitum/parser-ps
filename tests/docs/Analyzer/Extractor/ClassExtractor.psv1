@class final SineFine\Ponymator\Analyzer\Extractor\ClassExtractor
<SineFine\Ponymator\Analyzer\Extractor\EntityExtractorInterface
$-astHelper:\SineFine\Ponymator\Analyzer\Extractor\AstHelper
$-namespace:string
.+__construct
    $namespace:string
    $astHelper:\SineFine\Ponymator\Analyzer\Extractor\AstHelper
.+extract
    $node:\PhpParser\Node
    :array
.-modifiers
    $node:\PhpParser\Node\Stmt\Class_
    :array
.+supports
    $node:\PhpParser\Node
    :bool
