@class SineFine\Ponymator\Analyzer\FileExtractor
.+extractConstants
    $ast:array
    :array
.+extractFunctions
    $ast:array
    :array
.+extractGlobals
    $ast:array
    :array
    ^SineFine\Ponymator\Analyzer\Visitor\FileExtractingVisitor
    ^PhpParser\NodeTraverser
.-resolveDefault
    $default:\PhpParser\Node\Expr
    :string
.-resolveType
    $typeNode:\PhpParser\Node
    :string
